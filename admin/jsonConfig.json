{
  "i18n": false,
  "type": "tabs",
  "items": {
    "main": {
      "type": "panel",
      "label": "Geräte",
      "items": {
        "help1": {
          "type": "staticText",
          "text": "Bis zu 10 Geräte. Pro Gerät: Name, IP, Intervall in Sekunden. Standardintervall: 10 Sekunden."
        },
        "devices": {
          "type": "table",
          "label": "Zendure Geräte",
          "sm": 12,
          "md": 12,
          "lg": 12,
          "newLine": true,
          "items": [
            {
              "type": "text",
              "attr": "name",
              "title": "Name",
              "filter": false,
              "sort": true,
              "width": "35%"
            },
            {
              "type": "text",
              "attr": "ip",
              "title": "IP-Adresse",
              "filter": false,
              "sort": true,
              "width": "35%"
            },
            {
              "type": "number",
              "attr": "intervalSec",
              "title": "Intervall (s)",
              "min": 1,
              "step": 1,
              "width": "20%"
            }
          ]
        },
        "help2": {
          "type": "staticText",
          "text": "Der Adapter pollt fix http://<IP>/properties/report und legt die Daten unter zendure-ip.<geraetename> ab. Leerzeichen im Namen werden zu Bindestrichen."
        }
      }
    }
  }
}
